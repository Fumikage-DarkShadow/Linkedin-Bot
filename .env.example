# Copier ce fichier en `.env` et remplir les 2 valeurs.
# .env est gitignore donc ne sera jamais committe.

# Cle API Anthropic Claude (https://console.anthropic.com/settings/keys)
# Format : sk-ant-api03-XXXX...
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# URL du webhook Make.com (https://eu1.make.com -> scenario -> module Webhook)
# Format : https://hook.eu1.make.com/XXXXX
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/REPLACE_ME

# Cle API Webhook Make.com (envoyee en header x-make-apikey pour authentifier les requetes)
# Configurer dans Make : Webhooks > linkedin-bot > Edit > Add API key
MAKE_WEBHOOK_API_KEY=REPLACE_ME_RANDOM_LONG_STRING

# Health check Make : permet de detecter si le scenario est inactif avant de poster.
# Token a creer sur https://eu1.make.com/en/users/me/api
MAKE_API_TOKEN=REPLACE_ME_MAKE_PROFILE_API_TOKEN

# ID numerique du scenario (visible dans l'URL : .../scenarios/<SCENARIO_ID>/edit)
MAKE_SCENARIO_ID=REPLACE_ME_SCENARIO_ID

# Optionnel : NewsAPI pour elargir le sourcing (non requis, le bot marche avec les RSS seuls)
# NEWSAPI_KEY=
