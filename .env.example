# Copier ce fichier en `.env` et remplir les 2 valeurs.
# .env est gitignore donc ne sera jamais committe.

# Cle API Anthropic Claude (https://console.anthropic.com/settings/keys)
# Format : sk-ant-api03-XXXX...
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# URL du webhook Make.com (https://eu1.make.com -> scenario -> module Webhook)
# Format : https://hook.eu1.make.com/XXXXX
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/REPLACE_ME

# Optionnel : NewsAPI pour elargir le sourcing (non requis, le bot marche avec les RSS seuls)
# NEWSAPI_KEY=
